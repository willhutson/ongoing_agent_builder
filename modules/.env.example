# SpokeStack Modular Agent Platform
# Copy to .env and fill in your OpenRouter key.

# The only key you need — routes to any model via OpenRouter
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Default models (OpenRouter model IDs) — change to use different providers
# MODEL_PREMIUM=anthropic/claude-opus-4-20250514
# MODEL_STANDARD=anthropic/claude-sonnet-4-20250514
# MODEL_ECONOMY=anthropic/claude-haiku-3.5
# MODEL_CREATIVE=moonshotai/kimi-k2.5
# MODEL_VISION=openai/gpt-5-image-mini

# Or use non-Anthropic models:
# MODEL_STANDARD=deepseek/deepseek-v3.2
# MODEL_ECONOMY=tngtech/deepseek-r1t2-chimera:free
# MODEL_CREATIVE=qwen/qwen3.5-flash
# MODEL_VISION=google/gemini-2.5-flash-image

# Wizard agent model — defaults to MODEL_PREMIUM (Opus)
# Override to use a different model for the onboarding concierge
# WIZARD_MODEL=anthropic/claude-opus-4-20250514
# WIZARD_MODEL=google/gemini-2.5-pro-preview  # great for large doc ingestion

# Mission Control port (public-facing)
# MISSION_CONTROL_PORT=8000

# Logging
# LOG_LEVEL=INFO
